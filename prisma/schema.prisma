// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Building {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code       String  @unique
  name       String
  country    String
  state      String?
  city       String
  address    String
  postalCode String? @map("postal_code")
  latitude   Float?
  longitude  Float?
  timezone   String
  status     String  @default("active")
  ownerName  String? @map("owner_name")

  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  archivedAt DateTime? @map("archived_at")

  floors           Floor[]
  blueprintImports BlueprintImport[]
  navigationGraphs NavigationGraph[]

  @@index([status])
  @@index([city, country])
  @@map("buildings")
}

model Floor {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  buildingId   String  @map("building_id") @db.Uuid
  level        Int
  name         String
  shortName    String? @map("short_name")
  displayOrder Int?    @map("display_order")
  publicAccess Boolean @default(true) @map("public_access")
  status       String  @default("draft")

  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  archivedAt DateTime? @map("archived_at")

  building         Building          @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  assets           Asset[]
  blueprint        Blueprint?
  blueprintImports BlueprintImport[]
  navigationGraphs NavigationGraph[]

  @@unique([buildingId, level])
  @@index([buildingId])
  @@index([status])
  @@map("floors")
}

model Asset {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  floorId          String   @map("floor_id") @db.Uuid
  type             String
  filename         String
  originalFilename String   @map("original_filename")
  mimeType         String   @map("mime_type")
  fileSize         Int      @map("file_size")
  checksum         String?
  storageProvider  String   @default("local") @map("storage_provider")
  bucket           String?
  objectKey        String   @map("object_key")
  uploadedBy       String?  @map("uploaded_by")
  uploadedAt       DateTime @default(now()) @map("uploaded_at")
  processingStatus String   @default("pending") @map("processing_status")
  metadata         Json     @default("{}")

  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  archivedAt DateTime? @map("archived_at")

  floor      Floor       @relation(fields: [floorId], references: [id], onDelete: Cascade)
  blueprints Blueprint[]

  @@unique([storageProvider, bucket, objectKey])
  @@index([floorId])
  @@index([processingStatus])
  @@index([checksum])
  @@map("assets")
}

model Blueprint {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  floorId          String    @unique @map("floor_id") @db.Uuid
  assetId          String    @map("asset_id") @db.Uuid
  version          Int       @default(1)
  status           String    @default("pending")
  width            Float?
  height           Float?
  scale            Float?
  rotation         Float     @default(0)
  originX          Float     @default(0) @map("origin_x")
  originY          Float     @default(0) @map("origin_y")
  processingStatus String    @default("pending") @map("processing_status")
  importedAt       DateTime? @map("imported_at")
  generatedAt      DateTime? @map("generated_at")
  metadata         Json      @default("{}")

  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  archivedAt DateTime? @map("archived_at")

  floor Floor @relation(fields: [floorId], references: [id], onDelete: Cascade)
  asset Asset @relation(fields: [assetId], references: [id], onDelete: Restrict)

  spatialObjects        SpatialObject[]
  legacyNavigationGraph LegacyNavigationGraph?

  @@index([assetId])
  @@index([status])
  @@map("blueprints")
}

enum SpatialObjectCategory {
  ARCHITECTURE
  NAVIGATION
  ACCESSIBILITY
  EMERGENCY
  ANNOTATION
  EVENTS
  MAINTENANCE

  @@map("spatial_object_category")
}

enum SpatialObjectType {
  WALL
  DOOR
  WINDOW
  ROOM
  STORE
  STAIR
  ELEVATOR
  ESCALATOR
  WASHROOM
  FIRE_EXIT
  ATM
  PARKING_SPACE
  BEACON
  AR_ANCHOR
  POI
  QUEUE_ZONE
  KIOSK
  COLUMN
  RAMP

  @@map("spatial_object_type")
}

enum GeometryType {
  POINT
  LINE
  POLYGON

  @@map("geometry_type")
}

// Sprint 03 Story 03 — the original (pre-Semantic-Model) graph status enum.
// Superseded by NavigationGraphLifecycleStatus, which drives the canonical
// Sprint 06 NavigationGraph below. Kept only because LegacyNavigationGraph
// still references it; not used by any new code.
enum LegacyGraphStatus {
  DRAFT
  BUILDING
  READY
  PUBLISHED
  ARCHIVED

  @@map("legacy_graph_status")
}

model SpatialObject {
  id            String                               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  blueprintId   String                               @map("blueprint_id") @db.Uuid
  category      SpatialObjectCategory
  type          SpatialObjectType
  subtype       String?
  name          String?
  code          String?
  geometry      Unsupported("geometry(Geometry, 0)")
  geometryType  GeometryType                         @map("geometry_type")
  level         Int
  zIndex        Int                                  @default(0) @map("z_index")
  accessibility Boolean                              @default(true)
  navigable     Boolean                              @default(false)
  searchable    Boolean                              @default(true)
  metadata      Json                                 @default("{}")

  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  archivedAt DateTime? @map("archived_at")

  blueprint Blueprint @relation(fields: [blueprintId], references: [id], onDelete: Cascade)

  @@index([blueprintId])
  @@index([category])
  @@index([type])
  @@index([level])
  @@index([geometry], type: Gist)
  @@map("spatial_objects")
}

// Sprint 03 Story 03 — the original geometry-derived navigation graph
// container, predating ACSM/Geometry/USO/Semantic Model. Kept only because
// it is still exposed live via POST/GET /api/blueprints/:blueprintId/graph
// (src/modules/spatial/graph). Its child GraphNode/GraphEdge tables were
// removed in the Sprint 06 Story 01 refactor: confirmed dead (no service,
// controller, or route ever created/read a row in either table). Atlas's
// canonical Navigation Graph is now NavigationGraph below — nothing new
// should be built on this legacy model.
model LegacyNavigationGraph {
  id          String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  blueprintId String            @unique @map("blueprint_id") @db.Uuid
  version     Int               @default(1)
  status      LegacyGraphStatus @default(DRAFT)
  generatedAt DateTime?         @map("generated_at")
  generatedBy String?           @map("generated_by")
  metadata    Json              @default("{}")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  blueprint Blueprint @relation(fields: [blueprintId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("legacy_navigation_graphs")
}

// Sprint 05 Story 01 — Blueprint Import Pipeline.
// Tracks the raw, opaque upload and its lifecycle (Stage 1 of the Spatial
// Processing Pipeline). Distinct from Blueprint (Sprint 03), which represents
// the normalized spatial representation produced by later pipeline stages.
enum BlueprintImportStatus {
  UPLOADED
  VALIDATING
  FAILED
  NORMALIZED

  @@map("blueprint_import_status")
}

model BlueprintImport {
  id               String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  buildingId       String                @map("building_id") @db.Uuid
  floorId          String                @map("floor_id") @db.Uuid
  version          Int
  originalFilename String                @map("original_filename")
  mimeType         String                @map("mime_type")
  fileSize         Int                   @map("file_size")
  checksum         String
  storageProvider  String                @default("local") @map("storage_provider")
  storageKey       String                @map("storage_key")
  status           BlueprintImportStatus @default(UPLOADED)
  errorMessage     String?               @map("error_message")
  metadata         Json                  @default("{}")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  floor    Floor    @relation(fields: [floorId], references: [id], onDelete: Cascade)

  normalizedBlueprint NormalizedBlueprint?

  @@unique([floorId, version])
  @@index([buildingId])
  @@index([floorId])
  @@index([status])
  @@index([checksum])
  @@map("blueprint_imports")
}

// Sprint 05 Story 02 — Blueprint Validation & Normalization.
// Persisted Atlas Canonical Spatial Model (ACSM): the format-agnostic,
// canonical representation every later pipeline stage (geometry extraction,
// USO generation, navigation graph generation) will consume instead of the
// original file. One per BlueprintImport (immutable input -> immutable
// normalized output); a re-normalization would only ever happen for a new
// BlueprintImport version, never by mutating this row.
model NormalizedBlueprint {
  id                String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  blueprintImportId String @unique @map("blueprint_import_id") @db.Uuid
  sourceFormat      String @map("source_format")
  coordinateSystem  Json   @map("coordinate_system")
  bounds            Json
  layers            Json
  elements          Json
  relationships     Json   @default("[]")
  metadata          Json   @default("{}")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  blueprintImport BlueprintImport @relation(fields: [blueprintImportId], references: [id], onDelete: Cascade)
  geometryModel   GeometryModel?

  @@map("normalized_blueprints")
}

// Sprint 05 Story 03 Phase A — Geometry Extraction Engine skeleton.
// Persisted output of the Geometry Extraction Engine: primitives collected
// from the ACSM, minimally cleaned, plus skeleton containers for topology /
// candidate objects / relationships that later phases populate with real
// algorithms. One per NormalizedBlueprint, same immutable-stage-output
// pattern as NormalizedBlueprint itself.
model GeometryModel {
  id                    String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  normalizedBlueprintId String @unique @map("normalized_blueprint_id") @db.Uuid
  primitives            Json
  cleanedGeometry       Json   @map("cleaned_geometry")
  topology              Json
  candidateObjects      Json   @map("candidate_objects")
  relationships         Json   @default("[]")
  diagnostics           Json

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  normalizedBlueprint     NormalizedBlueprint                  @relation(fields: [normalizedBlueprintId], references: [id], onDelete: Cascade)
  universalSpatialObjects UniversalSpatialObject[]
  usoRelationships        UniversalSpatialObjectRelationship[]

  @@map("geometry_models")
}

// Sprint 05 Story 04 Phase A — Universal Spatial Object Generation Engine.
// One row per generated USO (not a JSON blob column) — mirrors the Sprint 03
// SpatialObject precedent, since "USO identity must remain stable" and later
// phases (semantic classification, navigation graph generation) will need to
// enrich individual USOs in place without touching the rest of the batch.
enum UsoSpatialCategory {
  BOUNDARY
  WALL
  ENCLOSURE
  OPENING
  PASSAGE
  VERTICAL_CONNECTION

  @@map("uso_spatial_category")
}

// Sprint 05 Story 04 Phase C — lifecycle. GENERATED is the initial state for
// every new USO; production validation (post-persistence) may promote it to
// VALIDATED. PUBLISHED/DEPRECATED exist as destination states for future
// workflows — this phase implements neither the publishing nor the approval
// workflow that would transition into them.
enum UsoLifecycleStatus {
  GENERATED
  VALIDATED
  PUBLISHED
  DEPRECATED

  @@map("uso_lifecycle_status")
}

model UniversalSpatialObject {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  geometryModelId   String             @map("geometry_model_id") @db.Uuid
  candidateId       String             @map("candidate_id")
  candidateType     String             @map("candidate_type")
  spatialCategory   UsoSpatialCategory @map("spatial_category")
  version           Int                @default(1)
  // Lightweight version metadata (not version history): bumped whenever this
  // same row is meaningfully updated in place (e.g. a lifecycle transition),
  // so a consumer can tell "has this been touched since generation" without
  // a separate history table or a duplicate representation.
  revision          Int                @default(1)
  status            UsoLifecycleStatus @default(GENERATED)
  generatedAt       DateTime           @default(now()) @map("generated_at")
  generatedFrom     String             @map("generated_from")
  geometryReference Json               @map("geometry_reference")
  accessibility     Json
  // Vestigial Phase A placeholder — superseded by UniversalSpatialObjectRelationship
  // (Phase B persists relationships as first-class rows, not an embedded array).
  // Left in place rather than removed, per "do not redesign existing architecture".
  // Always empty going forward; the API response's `relationships` field is
  // populated by joining the dedicated relationship table instead.
  relationships     Json               @default("[]")
  metadata          Json               @default("{}")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  geometryModel       GeometryModel                        @relation(fields: [geometryModelId], references: [id], onDelete: Cascade)
  sourceRelationships UniversalSpatialObjectRelationship[] @relation("SourceUso")
  targetRelationships UniversalSpatialObjectRelationship[] @relation("TargetUso")
  semanticModel       SemanticModel?

  @@unique([geometryModelId, candidateId])
  @@index([geometryModelId])
  @@index([spatialCategory])
  @@map("universal_spatial_objects")
}

// Sprint 05 Story 04 Phase B — relationships persisted as first-class rows,
// not attached arrays. Deterministic only: every row is derived directly
// from Phase C's candidate-level relationships (geometry/topology), never
// from names, metadata, or inference — hence confidence is always 1.0 today.
enum UsoRelationshipType {
  ADJACENT_TO
  CONTAINS
  WITHIN
  BOUNDED_BY
  CONNECTS
  TOUCHES
  INTERSECTS

  @@map("uso_relationship_type")
}

model UniversalSpatialObjectRelationship {
  id               String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  geometryModelId  String              @map("geometry_model_id") @db.Uuid
  sourceUsoId      String              @map("source_uso_id") @db.Uuid
  targetUsoId      String              @map("target_uso_id") @db.Uuid
  relationshipType UsoRelationshipType @map("relationship_type")
  confidence       Float               @default(1.0)
  metadata         Json                @default("{}")

  createdAt DateTime @default(now()) @map("created_at")

  geometryModel GeometryModel          @relation(fields: [geometryModelId], references: [id], onDelete: Cascade)
  sourceUso     UniversalSpatialObject @relation("SourceUso", fields: [sourceUsoId], references: [id], onDelete: Cascade)
  targetUso     UniversalSpatialObject @relation("TargetUso", fields: [targetUsoId], references: [id], onDelete: Cascade)

  @@unique([sourceUsoId, targetUsoId, relationshipType])
  @@index([geometryModelId])
  @@index([sourceUsoId])
  @@index([targetUsoId])
  @@index([relationshipType])
  @@map("uso_relationships")
}

// Sprint 05 Story 05 Phase A — Semantic Classification Framework.
// The Semantic Model references a USO but never modifies it — geometry and
// spatial identity remain the USO's exclusive concern; this table stores
// only interpretation. One per USO (usoId unique): this phase's framework
// creates every row as UNCLASSIFIED with a zero-confidence placeholder,
// since no classification rule is implemented yet. The lifecycle mirrors
// classification-rules.md's own "Deterministic Rules -> Machine Learning ->
// Human Verification -> Published Semantic Model" evolution.
// Sprint 05 Story 05 Phase C — production lifecycle. Renamed from the
// Phase B value set (UNCLASSIFIED/CLASSIFIED/VERIFIED/PUBLISHED), which
// conflated "was this classified" (a semantic outcome, still visible via
// semanticCategory being null or not) with "is this row production-ready"
// (a lifecycle concern). Mirrors UsoLifecycleStatus's naming for
// consistency, but stays a distinct enum: a USO's lifecycle and a Semantic
// Model's lifecycle are independent concepts that happen to share state
// names today. Every new row starts GENERATED; no automatic transition
// beyond that is implemented in this phase.
enum SemanticLifecycleStatus {
  GENERATED
  VALIDATED
  PUBLISHED
  DEPRECATED

  @@map("semantic_lifecycle_status")
}

model SemanticModel {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  usoId                 String                  @unique @map("uso_id") @db.Uuid
  geometryModelId       String                  @map("geometry_model_id") @db.Uuid
  semanticVersion       Int                     @default(1) @map("semantic_version")
  // Version of the rule catalog active when this row was classified —
  // distinct from ruleVersion (the specific winning rule's own version).
  classificationVersion String                  @map("classification_version")
  // Version of the overall semantic pipeline orchestration (the 9 stages).
  pipelineVersion       String                  @map("pipeline_version")
  // Version of the rule-execution engine itself, distinct from both of the
  // above — a future engine rewrite could change this without touching the
  // rule catalog or the pipeline's stage wiring.
  engineVersion         String                  @map("engine_version")
  lifecycle             SemanticLifecycleStatus @default(GENERATED)
  semanticCategory      String?                 @map("semantic_category")
  semanticSubCategory   String?                 @map("semantic_sub_category")
  classificationSource  String?                 @map("classification_source")
  ruleId                String?                 @map("rule_id")
  ruleVersion           Int?                    @map("rule_version")
  confidenceValue       Float                   @map("confidence_value")
  confidenceSource      String                  @map("confidence_source")
  confidenceReason      String                  @map("confidence_reason")
  classifiedAt          DateTime?               @map("classified_at")
  metadata              Json                    @default("{}")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  uso UniversalSpatialObject @relation(fields: [usoId], references: [id], onDelete: Cascade)

  navigationNode       NavigationNode?
  navigationCandidates NavigationCandidate[]

  @@index([geometryModelId])
  @@index([lifecycle])
  @@index([semanticCategory])
  @@map("semantic_models")
}

// Sprint 06 Story 01 — Navigation Graph Domain Model.
// This is Atlas's single canonical Navigation Graph, derived from the
// Semantic Model. Persistence-only: no generation, candidate detection,
// validation algorithms, optimization, or routing logic belongs here (those
// arrive in later Sprint 06 stories and Sprint 07).
//
// Originally named SemanticNavigationGraph/Node/Edge during Story 01 Phase
// A to avoid colliding with the dormant-but-still-named NavigationGraph/
// GraphNode/GraphEdge from Sprint 03 Story 03. The Sprint 06 Story 01
// architectural refactor promoted this to the canonical name: the Sprint 03
// models were confirmed to have zero foreign-key or code references outside
// their own group except one live endpoint on the graph container itself
// (POST/GET /api/blueprints/:blueprintId/graph), which was preserved as
// LegacyNavigationGraph. GraphNode/GraphEdge were confirmed fully dead
// (never read or written by any service/controller/route) and removed
// entirely. See LegacyNavigationGraph above for details.
enum NavigationGraphLifecycleStatus {
  CREATED
  GENERATING
  VALIDATING
  READY
  FAILED

  @@map("navigation_graph_lifecycle_status")
}

model NavigationGraph {
  id              String                         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  buildingId      String                         @map("building_id") @db.Uuid
  floorId         String?                        @map("floor_id") @db.Uuid
  status          NavigationGraphLifecycleStatus @default(CREATED)
  pipelineVersion String                         @map("pipeline_version")
  metadata        Json                           @default("{}")
  statistics      Json                           @default("{}")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  floor    Floor?   @relation(fields: [floorId], references: [id], onDelete: Cascade)

  candidates        NavigationCandidate[]
  nodes             NavigationNode[]
  edges             NavigationEdge[]
  validationReports GraphValidationReport[]

  @@index([buildingId])
  @@index([floorId])
  @@index([status])
  @@map("navigation_graphs")
}

// Sprint 06 Story 02 Phase A — Navigation Candidate Detection.
// Intermediate pipeline artifact: identifies WHERE a navigation node should
// eventually exist, before any NavigationNode is created (Story 03). Always
// references a Semantic Object — never Geometry, ACSM, or Blueprint directly.
// Scoped per-graph (not globally unique on semanticObjectId) so a stale
// graph can be discarded and candidates regenerated for a fresh graph over
// the same Semantic Model without a unique-constraint collision.
enum NavigationCandidateType {
  ROOM_ENTRY
  CORRIDOR_INTERSECTION
  DEAD_END
  VERTICAL_CONNECTOR
  BUILDING_ENTRY

  @@map("navigation_candidate_type")
}

model NavigationCandidate {
  id               String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  graphId          String                  @map("graph_id") @db.Uuid
  semanticObjectId String                  @map("semantic_object_id") @db.Uuid
  candidateType    NavigationCandidateType @map("candidate_type")
  position         Json                    @default("{}")
  confidence       Float                   @default(1.0)
  metadata         Json                    @default("{}")

  createdAt DateTime @default(now()) @map("created_at")

  graph          NavigationGraph @relation(fields: [graphId], references: [id], onDelete: Cascade)
  semanticObject SemanticModel   @relation(fields: [semanticObjectId], references: [id], onDelete: Cascade)

  navigationNode NavigationNode?

  @@unique([graphId, semanticObjectId])
  @@index([graphId])
  @@index([candidateType])
  @@map("navigation_candidates")
}

// Sprint 06 Story 03 — Navigation Node Generation.
// Strict 1:1 with the NavigationCandidate it was generated from (never
// merged, never split) — candidateId is unique to enforce that at the DB
// level. Deterministic transformation only: nodeType/position/metadata are
// inherited verbatim from the candidate, never recomputed or reclassified.
model NavigationNode {
  id               String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  graphId          String @map("graph_id") @db.Uuid
  candidateId      String @unique @map("candidate_id") @db.Uuid
  semanticObjectId String @unique @map("semantic_object_id") @db.Uuid
  nodeType         String @map("node_type")
  position         Json
  metadata         Json   @default("{}")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  graph          NavigationGraph     @relation(fields: [graphId], references: [id], onDelete: Cascade)
  candidate      NavigationCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  semanticObject SemanticModel       @relation(fields: [semanticObjectId], references: [id], onDelete: Cascade)

  edgesAsSource NavigationEdge[] @relation("NavigationEdgeSourceNode")
  edgesAsTarget NavigationEdge[] @relation("NavigationEdgeTargetNode")

  @@index([graphId])
  @@index([nodeType])
  @@map("navigation_nodes")
}

model NavigationEdge {
  id            String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  graphId       String @map("graph_id") @db.Uuid
  sourceNodeId  String @map("source_node_id") @db.Uuid
  targetNodeId  String @map("target_node_id") @db.Uuid
  edgeType      String @map("edge_type")
  length        Float?
  traversalCost Float  @default(1) @map("traversal_cost")
  accessibility Json   @default("{}")
  metadata      Json   @default("{}")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  graph      NavigationGraph @relation(fields: [graphId], references: [id], onDelete: Cascade)
  sourceNode NavigationNode  @relation("NavigationEdgeSourceNode", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode NavigationNode  @relation("NavigationEdgeTargetNode", fields: [targetNodeId], references: [id], onDelete: Cascade)

  @@index([graphId])
  @@index([sourceNodeId])
  @@index([targetNodeId])
  @@map("navigation_edges")
}

enum GraphValidationStatus {
  VALID
  VALID_WITH_WARNINGS
  INVALID

  @@map("graph_validation_status")
}

model GraphValidationReport {
  id               String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  graphId          String                 @map("graph_id") @db.Uuid
  validationStatus GraphValidationStatus? @map("validation_status")
  warnings         Json                   @default("[]")
  errors           Json                   @default("[]")
  statistics       Json                   @default("{}")
  validatedAt      DateTime?              @map("validated_at")

  createdAt DateTime @default(now()) @map("created_at")

  graph NavigationGraph @relation(fields: [graphId], references: [id], onDelete: Cascade)

  @@index([graphId])
  @@map("graph_validation_reports")
}
